# Backend
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/dp_di
CORS_ORIGIN=http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=replace-this-before-deployment
API_KEY=replace-this-with-your-demo-api-key
FRED_API_KEY=replace-this-with-your-fred-api-key
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=mistral
OLLAMA_KEEP_ALIVE=10m
OLLAMA_TIMEOUT_MS=8000
OLLAMA_TEST_TIMEOUT_MS=65000
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=180
OLLAMA_TEMPERATURE=0.25
AUTH_ADMIN_PASSWORD=admin123
AUTH_ANALYST_PASSWORD=analyst123
# Optional: use hashed passwords instead of plaintext demo passwords.
# Generate with the backend scrypt helper or leave blank for local demo mode.
AUTH_ADMIN_PASSWORD_HASH=
AUTH_ANALYST_PASSWORD_HASH=

# Frontend
VITE_API_BASE_URL=http://localhost:5000
VITE_API_KEY=replace-this-with-your-demo-api-key
